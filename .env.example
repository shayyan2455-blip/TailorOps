# Supabase — get these from your project dashboard at Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Gmail SMTP — for sending invitation emails via /api/send-invite-email
# SMTP_PASS must be a Gmail App Password (not your regular password)
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=your.email@gmail.com
APP_URL=https://tailorops.vercel.app

# For local dev, copy this file as .env.local and fill in the values.
# For Vercel, add these as environment variables in the project dashboard.
